# ============================================================
# Oeconomia Twitter Agent — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (DALL-E 3) ---
OPENAI_API_KEY=sk-...

# --- Twitter / X API (v2 + v1.1) ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Agent Behavior ---
# DRY_RUN=true → logs tweet text but does NOT post to Twitter
DRY_RUN=true

# IMAGE_MODE: "dalle" | "manual" | "none"
#   dalle  → auto-generate image via DALL-E 3 and attach
#   manual → generate prompt, log it, but don't call DALL-E (you supply images)
#   none   → text-only tweets, no image prompt generated
IMAGE_MODE=manual

# How many posts per day (randomly spread 8 AM – 10 PM)
POST_FREQUENCY_MIN=2
POST_FREQUENCY_MAX=4

# Timezone for scheduling (IANA format)
TIMEZONE=America/Los_Angeles

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-5
